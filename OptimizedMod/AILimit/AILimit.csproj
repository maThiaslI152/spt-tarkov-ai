<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <RootNamespace>dvize.AILimit</RootNamespace>
    <AssemblyName>dvize.AILimit</AssemblyName>
    <Configurations>Debug;Release</Configurations>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <NoStdLib>true</NoStdLib>
    <OutputType>Library</OutputType>
  </PropertyGroup>

  <!-- Use Unity's mscorlib as the standard library -->
  <ItemGroup>
    <Reference Include="mscorlib">
      <HintPath>$(SPTManaged)\mscorlib.dll</HintPath>
    </Reference>
    <Reference Include="System">
      <HintPath>$(SPTManaged)\System.dll</HintPath>
    </Reference>
    <Reference Include="System.Configuration">
      <HintPath>$(SPTManaged)\System.Configuration.dll</HintPath>
    </Reference>
    <Reference Include="System.Core">
      <HintPath>$(SPTManaged)\System.Core.dll</HintPath>
    </Reference>
  </ItemGroup>

  <!-- Exclude Visual Studio designer-generated files (incompatible with Unity mono) -->
  <ItemGroup>
    <Compile Remove="Properties\Settings.Designer.cs" />
    <Compile Remove="Properties\Resources.Designer.cs" />
    <EmbeddedResource Remove="Properties\Resources.resx" />
    <None Remove="Properties\Settings.settings" />
  </ItemGroup>

  <!-- References from SPT Core (BepInEx) -->
  <ItemGroup>
    <Reference Include="0Harmony">
      <HintPath>$(SPTCore)\0Harmony.dll</HintPath>
    </Reference>
    <Reference Include="BepInEx">
      <HintPath>$(SPTCore)\BepInEx.dll</HintPath>
    </Reference>
  </ItemGroup>

  <!-- References from SPT Managed (Unity) -->
  <ItemGroup>
    <Reference Include="Assembly-CSharp">
      <HintPath>$(SPTManaged)\Assembly-CSharp.dll</HintPath>
    </Reference>
    <Reference Include="Comfort">
      <HintPath>$(SPTManaged)\Comfort.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine">
      <HintPath>$(SPTManaged)\UnityEngine.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(SPTManaged)\UnityEngine.CoreModule.dll</HintPath>
    </Reference>
  </ItemGroup>

  <!-- References from SPT SPT plugins -->
  <ItemGroup>
    <Reference Include="spt-common">
      <HintPath>$(SPTSPT)\spt-common.dll</HintPath>
    </Reference>
    <Reference Include="spt-reflection">
      <HintPath>$(SPTSPT)\spt-reflection.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
